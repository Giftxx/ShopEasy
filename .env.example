# ShopEasy Environment Variables
APP_NAME="ShopEasy Backend"
APP_ENV=development
API_V1_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+psycopg://LLM-project-shopeasy:LLm-260346@db:5432/shopeasy

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# MinIO
MINIO_ENDPOINT=minio:9000
